# Database
# Local dev example:
# DATABASE_URL=sqlite:///./unify_zoho.db
# Production example:
DATABASE_URL=postgresql+psycopg://your_user:your_password@your_host:5432/your_database

# Unify API config
UNIFY_BASE_URL=https://api.unifyordering.com
UNIFY_CLIENT_ID=your_unify_client_id
UNIFY_CLIENT_SECRET=your_unify_client_secret

# Zoho Invoice OAuth config
ZOHO_BASE_URL=https://www.zohoapis.eu
ZOHO_CLIENT_ID=your_zoho_client_id
ZOHO_CLIENT_SECRET=your_zoho_client_secret
ZOHO_REFRESH_TOKEN=your_zoho_refresh_token
ZOHO_ORG_ID=your_zoho_organization_id

# Debug flags
UNIFY_DEBUG_SHAPES=false
UNIFY_DEBUG_MONEY=false
UNIFY_DEBUG_SAMPLES=false
